    { "pattern": "**/positions.js", "regions": ["sidebar-right"] },
    { "pattern": "**/agents.js", "regions": ["main"] },
    { "pattern": "**/trading.js", "regions": ["main"] },
    { "pattern": "**/gauges.js", "regions": ["main"] },
    { "pattern": "**/logs.js", "regions": ["main"] },
    { "pattern": "**/paint.js", "regions": ["main"] },
    { "pattern": "**/rulers.js", "regions": ["main"] },
    { "pattern": "**/telemetry.js", "regions": ["main"] },
    { "pattern": "**/todo.js", "regions": ["main"] },
    { "pattern": "**/themes.js", "regions": ["action-bar"] }
  ]
