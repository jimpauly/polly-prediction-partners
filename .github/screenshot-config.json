    },
    "navbar": {
      "selector": "#nav-bar",
      "label": "Nav Bar (HUD)"
    },
    "sidebar": {
      "selector": "#left-sidebar",
      "label": "Sidebar (System Design)"
    },
    "sidebar-right": {
      "selector": "#right-sidebar",
      "label": "Right Sidebar (Inspector Panel)"
    },
    "bottom-bar": {
      "selector": "#bottom-bar",
      "label": "Bottom Bar (Hangar Bay)"
    },
    "action-bar": {
      "selector": "#action-bar",
      "label": "Action Bar (Ignition Panel)"
    },
    "main": {
      "selector": "#main-region",
      "label": "Main Region (Viewing Port)"
    }
