{
  "name": "paulies-prediction-partners",
  "version": "1.0.0",
  "description": "AI-Powered Prediction Market Trading Studio for Kalshi",
  "main": "electron/main.js",
  "author": "Paulie's Prediction Partners",
  "license": "MIT",
  "homepage": "https://github.com/jimpauly/paulies-prediction-partners",
  "repository": {
    "type": "git",
    "url": "https://github.com/jimpauly/paulies-prediction-partners.git"
  },
  "scripts": {
    "start": "electron .",
    "start:backend": "cd copilot-opus && python -m uvicorn backend.main:main --host 127.0.0.1 --port 8000",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder --win --mac --linux",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.paulies.prediction-partners",
    "productName": "Paulie's Prediction Partners",
    "files": [
      "electron/**/*",
      "copilot-opus/**/*",
      "index.html",
      "!copilot-opus/backend/**/*",
      "!**/node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "copilot-opus/backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!__pycache__/**",
          "!*.pyc"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "electron/icons/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "electron/icons/icon.icns",
      "category": "public.app-category.finance"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        }
      ],
      "icon": "electron/icons",
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "electron/icons/icon.ico",
      "uninstallerIcon": "electron/icons/icon.ico",
      "installerHeaderIcon": "electron/icons/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Paulie's Prediction Partners"
    },
    "dmg": {
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    }
  },
  "devDependencies": {
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8"
  }
}
