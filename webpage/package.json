{
  "name": "paulies-prediction-partners",
  "version": "1.0.0",
  "description": "Prediction Market Trading Studio for Kalshi",
  "main": "apps/desktop/main.js",
  "author": "Paulie's Prediction Partners",
  "license": "MIT",
  "homepage": "https://github.com/jimpauly/paulies-prediction-partners",
  "repository": {
    "type": "git",
    "url": "https://github.com/jimpauly/paulies-prediction-partners.git"
  },
  "scripts": {
    "start": "electron .",
    "start:backend": "cd services/api && python -m uvicorn backend.main:main --host 127.0.0.1 --port 8000",
    "start:web": "cd apps/web/public && python -m http.server 4173",
    "dev": "vite",
    "build:react": "tsc && vite build",
    "preview": "vite preview",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder --win --mac --linux",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.paulies.prediction-partners",
    "productName": "Paulie's Prediction Partners",
    "files": [
      "apps/desktop/**/*",
      "apps/web/public/**/*",
      "!services/api/backend/**/*",
      "!**/node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "services/api/backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!__pycache__/**",
          "!*.pyc"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icons/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icons/icon.icns",
      "category": "public.app-category.finance"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icons",
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icons/icon.ico",
      "uninstallerIcon": "build/icons/icon.ico",
      "installerHeaderIcon": "build/icons/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Paulie's Prediction Partners"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  },
  "dependencies": {
    "electron": "^35.7.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "electron-builder": "^26.8.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.1",
    "typescript": "^5.4.5",
    "vite": "^5.2.11"
  }
}
